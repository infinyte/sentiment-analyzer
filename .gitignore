# Environment files — never commit secrets
.env
.env.*
*.env

# Keep example templates in source control
!.env.example
!*.env.example

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Cache
.npm
.eslintcache
.parcelcache
.cache/

# SQLite databases (never commit data files)
*.db
*.db-shm
*.db-wal

# TypeScript
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
