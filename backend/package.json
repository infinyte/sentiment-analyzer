{
  "name": "sentiment-analyzer-backend",
  "version": "1.0.0",
  "description": "Sentiment analysis and altcoin trading intelligence backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/index.ts",
    "dev:tournament-worker": "nodemon --watch src --ext ts,json --exec tsx src/workers/tournament-worker-process.ts",
    "dev:scraper-worker": "nodemon --watch src --ext ts,json --exec tsx src/workers/scraper-worker-process.ts",
    "mcp:genetic-ops": "node dist/mcp/mcp-genetic-ops.js",
    "mcp:agent-manager": "node dist/mcp/mcp-agent-manager.js",
    "dev:mcp:genetic-ops": "tsx src/mcp/mcp-genetic-ops.ts",
    "dev:mcp:agent-manager": "tsx src/mcp/mcp-agent-manager.ts",
    "auth:benchmark-argon2": "tsx src/services/auth/benchmark-argon2.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker:tournament": "node dist/workers/tournament-worker-process.js",
    "worker:scraper": "node dist/workers/scraper-worker-process.js",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist logs"
  },
  "keywords": [
    "cryptocurrency",
    "sentiment-analysis",
    "trading",
    "ai",
    "claude",
    "altcoin"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.13.0",
    "@azure/data-tables": "^13.2.1",
    "@azure/identity": "^3.3.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/cookie-parser": "^1.4.10",
    "argon2": "^0.44.0",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.71.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jq": "^1.7.2",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "uuid": "^14.0.1",
    "winston": "^3.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
