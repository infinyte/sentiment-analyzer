# Sentiment Analyzer Backend Environment Template
#
# New runtime-config model:
# - Only bootstrap/security values are required in .env.
# - All other application settings can be managed at runtime from the Admin tab
#   and are persisted in the SQLite app_config table.
#
# Steps:
# 1) Copy this file to backend/.env
# 2) Set required values below
# 3) Start backend and open Admin tab in UI to configure remaining settings

# -----------------------------------------------------------------------------
# REQUIRED (keep in .env only)
# -----------------------------------------------------------------------------

# Required for encrypting DB-stored secrets (broker credentials and app_config secrets).
# Supports either:
# - 64-char hex string (used directly)
# - any string (SHA-256 derived)
BROKER_MASTER_KEY=

# Required to access GET/PATCH/DELETE /api/admin/config endpoints.
# Send as Authorization: Bearer <CONFIG_ADMIN_PASSWORD>
CONFIG_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# INFRASTRUCTURE / STARTUP (recommended in .env)
# -----------------------------------------------------------------------------

PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=*
DATABASE_PATH=./sentiment_analyzer.db
REDIS_URL=

# Worker process infra
TOURNAMENT_WORKER_CONCURRENCY=2
SCRAPER_WORKER_CONCURRENCY=1

# -----------------------------------------------------------------------------
# OPTIONAL MIGRATION FALLBACKS
# -----------------------------------------------------------------------------
# These are read as fallbacks if no DB value exists in app_config.
# Prefer setting them in Admin UI instead of .env.

# Core APIs
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
NEWSAPI_API_KEY=
API_SECRET_KEY=
FINBERT_API_URL=
HUGGINGFACE_API_TOKEN=
LUNARCRUSH_API_KEY=
ONCHAIN_API_KEY=
ONCHAIN_API_URL=

# Schedulers / runtime tuning
SENTIMENT_JOB_CRON=0 2 * * *
TRENDING_JOB_CRON=*/30 * * * *
SOCIAL_SCRAPE_CRON=0 * * * *
SENTIMENT_BATCH_SIZE=50
SENTIMENT_TTL_MS=3600000
TRENDING_MIN_MENTIONS=3
TRENDING_WINDOW_HOURS=24
SOCIAL_HISTORY_DAYS=30
SOCIAL_PRUNE_RETAIN_DAYS=30
INGEST_QUEUE_CONCURRENCY=4

# Social integrations
TWITTER_BEARER_TOKEN=
X_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_USERNAMES=
YOUTUBE_API_KEY=
RAPIDAPI_KEY=
RAPIDAPI_TIKTOK_HOST=tiktok-scraper7.p.rapidapi.com

