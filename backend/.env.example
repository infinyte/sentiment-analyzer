NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
NEWSAPI_API_KEY=your_newsapi_key_here
CLAUDE_API_KEY=your_claude_api_key_here
ALLOWED_ORIGINS=http://localhost:5173
API_SECRET_KEY=dev-secret-key

# SQLite persistence (backtest results + sentiment cache survive restarts)
# Path is relative to the backend/ directory. Leave blank to use the default.
DATABASE_PATH=./sentiment_analyzer.db

# ── Social Media Intelligence ─────────────────────────────────────────────────

# Twitter/X API v2 bearer token (optional — skipped if blank)
TWITTER_BEARER_TOKEN=

# Reddit OAuth2 credentials (optional — falls back to unauthenticated JSON API)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Discord bot token + comma-separated channel snowflake IDs to monitor
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=

# Telegram public channels to monitor (comma-separated usernames, no @)
# Defaults to cointelegraph,bitcoinnewscom,cryptonewscom,theblockresearch,coindeskmarkets
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_USERNAMES=

# YouTube Data API v3 key (optional — ~101 quota units per coin)
YOUTUBE_API_KEY=

# TikTok via RapidAPI (optional)
RAPIDAPI_KEY=
RAPIDAPI_TIKTOK_HOST=tiktok-scraper7.p.rapidapi.com

# Azure Application Insights (optional — send logs to Azure)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Social scrape cron schedule (default: every hour)
SOCIAL_SCRAPE_CRON=0 * * * *

# How many days of social items to retain in SQLite (default: 7)
SOCIAL_HISTORY_DAYS=7

# Trending topic discovery window in hours (default: 24)
TRENDING_WINDOW_HOURS=24

# Minimum mention count for a topic to appear in trending results (default: 3)
TRENDING_MIN_MENTIONS=3

# ── MARL endpoint rate limiting
# Shared limiter window in milliseconds.
MARL_RATE_LIMIT_WINDOW_MS=60000
# Max requests per window for POST /api/marl/competition/start
MARL_START_RATE_LIMIT_MAX=5
# Max requests per window for POST /api/marl/agents/compare
MARL_COMPARE_RATE_LIMIT_MAX=10
# Max requests per window for MARL read endpoints
MARL_READ_RATE_LIMIT_MAX=120