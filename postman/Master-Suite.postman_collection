              "            b.status !== undefined || b.success !== undefined || b.message !== undefined",
              "        );",
              "    });",
              "}",
              "",
              "if (url.includes(\"/tournaments/schedules\") && method === \"GET\" && !url.match(/\\/schedules\\/[^/]+/)) {",
              "    pm.test(\"List schedules: response is array or has schedules field\", () => {",
