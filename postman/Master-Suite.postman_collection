          "script": {
            "type": "text/javascript",
            "exec": [
              "// ── Tournament Scheduling & Live Control folder test suite ──────────────────",
              "const url = pm.request.url.toString();",
              "const method = pm.request.method;",
              "const isSseStream = url.includes(\"/stream\");",
              "",
              "// 1. Status code",
              "pm.test(\"Status code is 200, 201, or 204\", () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
              "});",
              "",
              "// 2. Response time",
              "pm.test(\"Response time is under 5000ms\", () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});",
              "",
              "if (isSseStream || pm.response.code === 204) { return; }",
              "",
              "// 3. Content-Type",
              "pm.test(\"Content-Type is application/json\", () => {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "// 4. Valid JSON",
              "let body;",
              "pm.test(\"Response body is valid JSON\", () => {",
              "    body = pm.response.json();",
              "    pm.expect(body).to.be.an(\"object\").or.to.be.an(\"array\");",
              "});",
              "",
              "if (!body) { return; }",
              "",
              "// 5. Domain-specific",
              "if (url.match(/\\/api\\/tournaments$/) && method === \"GET\") {",
              "    pm.test(\"List tournaments: response is array or has tournaments field\", () => {",
              "        const list = Array.isArray(body) ? body : body.tournaments || body.data;",
              "        pm.expect(list).to.be.an(\"array\");",
              "    });",
              "}",
              "",
              "if (url.includes(\"/tournaments/active\")) {",
              "    pm.test(\"Active tournaments: response is array or has tournaments field\", () => {",
              "        const list = Array.isArray(body) ? body : body.tournaments || body.data;",
              "        pm.expect(list).to.be.an(\"array\");",
              "    });",
              "}",
              "",
              "if (url.match(/\\/tournaments\\/[^/]+$/) && method === \"GET\" && !url.includes(\"/active\") && !url.includes(\"/schedules\")) {",
              "    pm.test(\"Tournament detail: id and status present\", () => {",
              "        pm.expect(body).to.satisfy(b => b.id !== undefined || b.tournamentId !== undefined);",
              "        pm.expect(body).to.have.property(\"status\");",
              "    });",
              "}",
              "",
              "if (url.includes(\"/tournaments/\") && (url.includes(\"/pause\") || url.includes(\"/resume\") || url.includes(\"/stop\"))) {",
              "    pm.test(\"Tournament control: status or success returned\", () => {",
