            "exec": [
              "// ── Core folder test suite ──────────────────────────────────────────────────",
              "const url = pm.request.url.toString();",
              "",
              "// 1. Status code",
              "pm.test(\"Status code is 200 or 202\", () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
              "});",
              "",
              "// 2. Response time",
              "pm.test(\"Response time is under 5000ms\", () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});",
              "",
              "// 3. Content-Type is JSON",
              "pm.test(\"Content-Type is application/json\", () => {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "// 4. Body is valid JSON",
              "let body;",
              "pm.test(\"Response body is valid JSON\", () => {",
              "    body = pm.response.json();",
              "    pm.expect(body).to.be.an(\"object\").or.to.be.an(\"array\");",
              "});",
              "",
              "if (!body) { return; }",
              "",
              "// 5. Domain-specific assertions",
              "if (url.includes(\"/api/health\")) {",
              "    pm.test(\"Health: status field is present\", () => {",
              "        pm.expect(body).to.have.property(\"status\");",
              "        pm.expect(body.status).to.be.a(\"string\");",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/coins\") && !url.includes(\"/api/coins/\")) {",
              "    pm.test(\"Coins list: response is an array or has data array\", () => {",
              "        const list = Array.isArray(body) ? body : body.data || body.coins || body.results;",
              "        pm.expect(list).to.be.an(\"array\");",
              "    });",
              "}",
              "",
              "if (url.match(/\\/api\\/coins\\/[^/]+/)) {",
              "    pm.test(\"Coin detail: symbol field is present\", () => {",
              "        pm.expect(body).to.have.property(\"symbol\");",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/sentiment/\") && !url.includes(\"analyze\")) {",
              "    pm.test(\"Sentiment: symbol and score fields present\", () => {",
              "        pm.expect(body).to.have.property(\"symbol\");",
              "        pm.expect(body).to.satisfy(b => b.score !== undefined || b.sentiment !== undefined);",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/sentiment/analyze\")) {",
              "    pm.test(\"Sentiment analyze: result field present\", () => {",
              "        pm.expect(body).to.satisfy(b =>",
              "            b.sentiment !== undefined || b.score !== undefined || b.result !== undefined",
              "        );",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/backtest/run\")) {",
              "    pm.test(\"Backtest run: jobId or testId returned\", () => {",
              "        pm.expect(body).to.satisfy(b =>",
              "            b.jobId !== undefined || b.testId !== undefined || b.id !== undefined",
              "        );",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/backtest/results/\")) {",
              "    pm.test(\"Backtest results: status field present\", () => {",
              "        pm.expect(body).to.have.property(\"status\");",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/rankings/top-coins\")) {",
              "    pm.test(\"Rankings: response is array or has coins array\", () => {",
              "        const list = Array.isArray(body) ? body : body.coins || body.data || body.results;",
              "        pm.expect(list).to.be.an(\"array\");",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/trending\") && !url.includes(\"ingest\")) {",
              "    pm.test(\"Trending: response is array or has items\", () => {",
              "        const list = Array.isArray(body) ? body : body.items || body.data || body.results;",
              "        pm.expect(list).to.be.an(\"array\");",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/refresh-sentiment\") || url.includes(\"/api/trending/ingest\") || url.includes(\"/api/scrape/batch\")) {",
              "    pm.test(\"Async job: jobId or accepted status returned\", () => {",
              "        pm.expect(body).to.satisfy(b =>",
              "            b.jobId !== undefined || b.id !== undefined || b.status !== undefined || b.accepted !== undefined",
              "        );",
              "    });",
              "}",
              "",
              "if (url.includes(\"/api/info/modes\")) {",
              "    pm.test(\"Modes: response is array or has modes field\", () => {",
              "        const list = Array.isArray(body) ? body : body.modes || body.data;",
              "        pm.expect(list).to.be.an(\"array\");",
              "    });",
              "}"
            ]
          }
        }
